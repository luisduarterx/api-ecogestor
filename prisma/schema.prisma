// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                         Int                       @id @default(autoincrement())
  nome                       String
  email                      String                    @unique
  senha                      String
  telefone                   String?
  cargoID                    Int                       @default(1)
  pedidos                    Pedido[]
  cargo                      Cargo                     @relation(fields: [cargoID], references: [id])
  deletedAt                  DateTime?
  movimentacoes_financeiras  MovimentacaoFinanceira[]
  transferencias_financeiras TransferenciaFinanceira[]
  lancamentos_financeiros    LancamentoFinanceiro[]
  caixas_abertos             Caixa[]                   @relation("UsuarioAbertura")
  caixas_fechados            Caixa[]                   @relation("UsuarioFechamento")
}

model Permissoes {
  id        Int     @id @default(autoincrement())
  nome      String  @unique
  descricao String?
  cargos    Cargo[] @relation("UserPermissions")
}

model Cargo {
  id         Int          @id @default(autoincrement())
  nome       String       @unique
  permissoes Permissoes[] @relation("UserPermissions")
  User       User[]
}

model Registro {
  id              Int                    @id @default(autoincrement())
  nome_razao      String
  apelido         String?
  tipo            TipoRegistro
  tabelaID        Int
  email           String?
  telefone        String?
  criadoEm        DateTime               @default(now())
  dados_pagamento DadosPagamento?
  endereco        Endereco?
  pedidos         Pedido[]
  fisica          PessoaFisica?
  juridica        PessoaJuridica?
  tabela          Tabela                 @relation(fields: [tabelaID], references: [id])
  saldo           SaldoFinanceiro?
  deletedAt       DateTime?
  lancamentos     LancamentoFinanceiro[]
}

model PessoaFisica {
  id         Int       @id @default(autoincrement())
  cpf        String    @unique
  nascimento DateTime?
  registroID Int       @unique
  registro   Registro  @relation(fields: [registroID], references: [id])
}

model PessoaJuridica {
  id         Int      @id @default(autoincrement())
  cnpj       String   @unique
  ie         String?
  fantasia   String?
  registroID Int      @unique
  registro   Registro @relation(fields: [registroID], references: [id])
}

model SaldoFinanceiro {
  id       Int      @id @default(autoincrement())
  regID    Int      @unique
  saldo    Decimal  @db.Decimal(10, 2)
  registro Registro @relation(fields: [regID], references: [id])
}

model Endereco {
  id          Int      @id @default(autoincrement())
  regID       Int      @unique
  cep         String?
  estado      String?
  cidade      String?
  bairro      String?
  logradouro  String?
  numero      String?
  complemento String?
  registro    Registro @relation(fields: [regID], references: [id])
}

model DadosPagamento {
  id       Int      @id @default(autoincrement())
  banco    String?
  agencia  String?
  conta    String?
  chave    String?
  cpf      String?
  regID    Int      @unique
  registro Registro @relation(fields: [regID], references: [id])
}

model Tabela {
  id        Int              @id @default(autoincrement())
  nome      String           @unique
  padrao    Boolean          @default(false)
  updatedAt DateTime         @default(now()) @updatedAt
  materiais PrecoPorTabela[]
  registros Registro[]
}

model PrecoPorTabela {
  id         Int      @id @default(autoincrement())
  v_compra   Decimal  @db.Decimal(10, 2)
  materialID Int
  tabelaID   Int
  editadoEm  DateTime @default(now()) @updatedAt
  material   Material @relation(fields: [materialID], references: [id])
  tabela     Tabela   @relation(fields: [tabelaID], references: [id])

  @@unique([tabelaID, materialID])
}

model Material {
  id            Int                   @id @default(autoincrement())
  nome          String                @unique
  catID         Int
  preco_venda   Decimal               @db.Decimal(10, 2)
  estoque       Decimal               @default(0) @db.Decimal(10, 2)
  criado_em     DateTime              @default(now())
  editado_em    DateTime              @default(now()) @updatedAt
  status        Boolean               @default(true)
  items         ItemPedido[]
  categoria     CategoriaMaterial     @relation(fields: [catID], references: [id])
  movimentacoes MovimentacaoEstoque[]
  preco_tabela  PrecoPorTabela[]
}

model CategoriaMaterial {
  id        Int        @id @default(autoincrement())
  nome      String     @unique
  materiais Material[]
}

model ItemPedido {
  id         Int      @id @default(autoincrement())
  pedidoID   Int
  materialID Int
  preco      Decimal  @db.Decimal(10, 2)
  quantidade Decimal  @db.Decimal(10, 2)
  pesoBruto  Decimal  @db.Decimal(10, 2)
  tara       Decimal  @db.Decimal(10, 2)
  impureza   Decimal  @db.Decimal(10, 2)
  subtotal   Decimal  @db.Decimal(10, 2)
  material   Material @relation(fields: [materialID], references: [id])
  pedido     Pedido   @relation(fields: [pedidoID], references: [id], onDelete: Cascade)
}

model Pedido {
  id            Int                    @id @default(autoincrement())
  regID         Int?
  caixaID       Int
  tipo          TipoPedido
  valor_total   Decimal                @default(0) @db.Decimal(10, 2)
  status        TipoStatusPedido       @default(ABERTO)
  userID        Int
  criado_em     DateTime               @default(now())
  atualizado    DateTime               @updatedAt
  items         ItemPedido[]
  lancamentos   LancamentoFinanceiro[]
  movimentacoes MovimentacaoEstoque[]
  caixa         Caixa                  @relation(fields: [caixaID], references: [id])
  registro      Registro?              @relation(fields: [regID], references: [id])
  user          User                   @relation(fields: [userID], references: [id])
}

model MovimentacaoEstoque {
  id                    Int                       @id @default(autoincrement())
  materialID            Int
  tipoMovimentacao      TipoMovimentacaoEstoque
  origem                OrigemMovimentacaoEstoque
  origemID              Int?
  devolucaoID           Int?                      @unique
  quantidade            Decimal                   @db.Decimal(10, 2)
  createdAt             DateTime                  @default(now())
  devolvidaEm           DateTime?
  observacao            String?
  pedidoID              Int?
  material              Material                  @relation(fields: [materialID], references: [id])
  pedido                Pedido?                   @relation(fields: [pedidoID], references: [id])
  devolucao             MovimentacaoEstoque?      @relation("Devolucao", fields: [devolucaoID], references: [id])
  movimentacaoDevolvida MovimentacaoEstoque?      @relation("Devolucao")

  @@index([pedidoID])
}

model ConversaoEstoque {
  id            Int      @id @default(autoincrement())
  mat_origemID  Int
  mat_destinoID Int
  quantidade    Decimal  @db.Decimal(10, 2)
  descricao     String?
  createdAt     DateTime @default(now())
}

model ContaFinanceira {
  id                     Int                       @id @default(autoincrement())
  nome                   String                    @unique
  criado_em              DateTime                  @default(now())
  atualizado_em          DateTime                  @updatedAt
  conta_padrao           Boolean                   @default(false)
  saldo_atual            Decimal                   @db.Decimal(10, 2)
  saldo_inicial          Decimal                   @db.Decimal(10, 2)
  status                 Boolean                   @default(true)
  movimentacoes          MovimentacaoFinanceira[]
  transferencias_origem  TransferenciaFinanceira[] @relation("ContaOrigem")
  transferencias_destino TransferenciaFinanceira[] @relation("ContaDestino")
  caixas                 Caixa[]
}

model CategoriaLancamento {
  id            Int                    @id @default(autoincrement())
  nome          String
  criado_em     DateTime               @default(now())
  TipoCategoria TipoCategoria
  lancamentos   LancamentoFinanceiro[]
}

model LancamentoFinanceiro {
  id            Int                      @id @default(autoincrement())
  valor         Decimal                  @db.Decimal(10, 2)
  descricao     String
  tipo          TipoLancamento
  titulo        String
  parcela       Int?
  status        StatusLancamento
  categoria_id  Int
  categoria     CategoriaLancamento      @relation(fields: [categoria_id], references: [id])
  vencimento    DateTime
  data_baixa    DateTime?
  criado_em     DateTime                 @default(now())
  atualizado_em DateTime                 @updatedAt
  desconto      Decimal                  @default(0) @db.Decimal(10, 2)
  acrescimo     Decimal                  @default(0) @db.Decimal(10, 2)
  user_id       Int
  usuario       User                     @relation(fields: [user_id], references: [id])
  movimentacoes MovimentacaoFinanceira[]
  registro_id   Int?
  registro      Registro?                @relation(fields: [registro_id], references: [id])
  pedido_id     Int?
  pedido        Pedido?                  @relation(fields: [pedido_id], references: [id])
  caixa_id      Int?
  caixa         Caixa?                   @relation(fields: [caixa_id], references: [id])

  @@index([caixa_id])
}

model MovimentacaoFinanceira {
  id               Int                      @id @default(autoincrement())
  conta_id         Int
  conta            ContaFinanceira          @relation(fields: [conta_id], references: [id])
  origem           OrigemMovimentacao
  origem_id        Int?
  descricao        String
  direcao          DirecaoFinanceira
  saldo_inicial    Decimal                  @db.Decimal(10, 2) ///
  valor            Decimal                  @db.Decimal(10, 2)
  saldo_final      Decimal                  @db.Decimal(10, 2)
  user_id          Int
  usuario          User                     @relation(fields: [user_id], references: [id])
  lancamento_id    Int?
  lancamento       LancamentoFinanceiro?    @relation(fields: [lancamento_id], references: [id])
  transferencia_id Int?
  transferencia    TransferenciaFinanceira? @relation(fields: [transferencia_id], references: [id])
  motivo_ajuste    String?
  estornada        Boolean                  @default(false)
  estorno_de_id    Int?                     @unique
  estorno_de       MovimentacaoFinanceira?  @relation("EstornoMovimentacao", fields: [estorno_de_id], references: [id])
  estornos         MovimentacaoFinanceira?  @relation("EstornoMovimentacao")
  caixa_id         Int?
  caixa            Caixa?                   @relation(fields: [caixa_id], references: [id])
}

model TransferenciaFinanceira {
  id               Int                      @id @default(autoincrement())
  conta_origem_id  Int
  conta_origem     ContaFinanceira          @relation("ContaOrigem", fields: [conta_origem_id], references: [id])
  conta_destino_id Int
  conta_destino    ContaFinanceira          @relation("ContaDestino", fields: [conta_destino_id], references: [id])
  valor            Decimal                  @db.Decimal(10, 2)
  descricao        String
  criado_em        DateTime                 @default(now())
  user_id          Int
  usuario          User                     @relation(fields: [user_id], references: [id])
  movimentacoes    MovimentacaoFinanceira[]
  caixa_id         Int?
  caixa            Caixa?                   @relation(fields: [caixa_id], references: [id])
  estornada        Boolean                  @default(false)
  estorno_de_id    Int?                     @unique
  estorno_de       TransferenciaFinanceira? @relation("EstornoTransferencia", fields: [estorno_de_id], references: [id])
  estorno          TransferenciaFinanceira? @relation("EstornoTransferencia")
}

model Caixa {
  id                    Int                       @id @default(autoincrement())
  conta_id              Int
  conta                 ContaFinanceira           @relation(fields: [conta_id], references: [id])
  usuario_abertura_id   Int
  usuario_abertura      User                      @relation("UsuarioAbertura", fields: [usuario_abertura_id], references: [id])
  usuario_fechamento_id Int?
  usuario_fechamento    User?                     @relation("UsuarioFechamento", fields: [usuario_fechamento_id], references: [id])
  status                StatusCaixa               @default(ABERTO)
  saldo_inicial         Decimal                   @db.Decimal(10, 2)
  saldo_final_sistema   Decimal?                  @db.Decimal(10, 2)
  saldo_final_informado Decimal?                  @db.Decimal(10, 2)
  diferenca             Decimal?                  @db.Decimal(10, 2)
  aberto_em             DateTime                  @default(now())
  fechado_em            DateTime?
  observacao_abertura   String?
  observacao_fechamento String?
  movimentacoes         MovimentacaoFinanceira[]
  transferencias        TransferenciaFinanceira[]
  pedidos               Pedido[]
  lancamentos           LancamentoFinanceiro[]
}

enum TipoRegistro {
  FISICA
  JURIDICA
}

enum TipoPedido {
  COMPRA
  VENDA
}

enum TipoStatusPedido {
  ABERTO
  FECHADO
  CANCELADO
}

enum FormaPagamento {
  DINHEIRO
  PIX
  TRANSFERENCIA
  ABATER
}

enum TipoMovimentacaoEstoque {
  VENDA
  COMPRA
  ENTRADA_MANUAL
  SAIDA_MANUAL
  ENTRADA_CONVERSAO
  SAIDA_CONVERSAO
}

enum OrigemMovimentacaoEstoque {
  PEDIDO
  CONVERSAO
  AVULSO
  AJUSTE
  DEVOLUCAO
}

enum StatusLancamento {
  ABERTO
  PAGO
  CANCELADO
}

enum TipoLancamento {
  PAGAR
  RECEBER
}

enum OrigemMovimentacao {
  PEDIDO_COMPRA
  PEDIDO_VENDA
  TRANSFERENCIA
  LANCAMENTO_PAGAR
  LANCAMENTO_RECEBER
  AJUSTE_MANUAL
  ABERTURA_CAIXA
  FECHAMENTO_CAIXA
  ESTORNO
}

enum DirecaoFinanceira {
  ENTRADA
  SAIDA
}

enum TipoCategoria {
  RECEITA
  DESPESA
}

enum StatusCaixa {
  ABERTO
  FECHADO
}
