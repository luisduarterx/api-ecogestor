{
  "name": "api-ecogestor",
  "version": "1.0.0",
  "main": "index.js",
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "scripts": {
    "test:ci": "vitest",
    "test": " node --env-file=.env node_modules/vitest/vitest.mjs",
    "test:full": "npm run services:delete && npm run services:up && npm run wait-for-postgres && prisma migrate deploy && node --env-file=.env node_modules/vitest/vitest.mjs",
    "dev": " npm run services:up && npm run wait-for-postgres && npm run migration:up && prisma db seed && tsx watch src/server.ts ",
    "services:up": "docker compose -f src/infra/compose.yaml up -d",
    "services:stop": "docker compose -f src/infra/compose.yaml down",
    "services:delete": "npm run services:stop && docker system prune -a",
    "migration:create": "prisma migrate dev",
    "migration:up": "prisma migrate deploy",
    "build": "tsc",
    "start": "node dist/server.js",
    "wait-for-postgres": "node src/infra/wait-for-postgres.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/js-cookie": "^3.0.6",
    "async-retry": "^1.3.3",
    "bcrypt": "^5.1.1",
    "body-parser": "^2.2.0",
    "cookie": "^1.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.21.0",
    "ts-node-dev": "^2.0.0",
    "uuid": "^11.1.0",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.5.0",
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.19.21",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "dotenv": "^17.4.2",
    "prisma": "^7.8.0",
    "set-cookie-parser": "^3.0.1",
    "supertest": "^7.2.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^4.1.9"
  }
}
